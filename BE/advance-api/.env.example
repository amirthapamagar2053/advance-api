# Supabase PostgreSQL — use Transaction Pooler URL (port 6543) for serverless
DATABASE_URL=postgresql://postgres.PROJECTID:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgBouncer=true&connection_limit=1

JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Supabase project settings → API → URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase project settings → API → service_role key (keep secret!)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Name of the storage bucket created in Supabase Storage
SUPABASE_BUCKET=receipts

# Set automatically by Render — do not set manually in Render dashboard
PORT=3000
